<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<DefineConstants>shiftFrameworkDevelopmentMode;includeSampleApp;internalShiftIdentityHosting;includeItemTemplateContent</DefineConstants>
		<ImportShiftFrameworkProjects>true</ImportShiftFrameworkProjects>
		<ShiftFrameworkVersion>2026.04.8.1</ShiftFrameworkVersion>
		<TypeAuthVersion>1.6.11</TypeAuthVersion>
		<AzureFunctionsAspNetCoreAuthorizationVersion>0.0.25</AzureFunctionsAspNetCoreAuthorizationVersion>
	</PropertyGroup>
</Project>