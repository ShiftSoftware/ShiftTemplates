<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<DefineConstants>shiftFrameworkDevelopmentMode;includeSampleApp;internalShiftIdentityHosting;includeItemTemplateContent</DefineConstants>
		<ImportShiftFrameworkProjects>true</ImportShiftFrameworkProjects>
		<ShiftFrameworkVersion>2026.05.22.1</ShiftFrameworkVersion>
		<TypeAuthVersion>1.6.15</TypeAuthVersion>
		<AzureFunctionsAspNetCoreAuthorizationVersion>0.0.28</AzureFunctionsAspNetCoreAuthorizationVersion>
	</PropertyGroup>
</Project>