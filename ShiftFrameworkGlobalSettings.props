<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<DefineConstants>shiftFrameworkDevelopmentMode;includeSampleApp;internalShiftIdentityHosting;includeItemTemplateContent</DefineConstants>
		<ImportShiftFrameworkProjects>true</ImportShiftFrameworkProjects>
		<ShiftFrameworkVersion>2026.03.20.1</ShiftFrameworkVersion>
		<TypeAuthVersion>1.6.9</TypeAuthVersion>
		<AzureFunctionsAspNetCoreAuthorizationVersion>0.0.24</AzureFunctionsAspNetCoreAuthorizationVersion>
	</PropertyGroup>
</Project>