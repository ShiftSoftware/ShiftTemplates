@using Microsoft.AspNetCore.Components.Authorization
@using ShiftSoftware.ShiftBlazor.Layouts

<DefaultApp AppTitle="StockPlusPlus"
            AppAssembly="@typeof(StockPlusPlus.Client._Imports).Assembly"
            AdditionalAssemblies="@additionalAssemblies">

    <NavMenuTemplate>
        <NavMenu isDrawerOpen="context.IsDrawerOpen"/>
    </NavMenuTemplate>
</DefaultApp>

@code {
    private System.Reflection.Assembly[] additionalAssemblies = new System.Reflection.Assembly[]
    {
@*#if (internalShiftIdentityHosting)*@
        typeof(ShiftSoftware.ShiftIdentity.Dashboard.Blazor.ShiftIdentityDashboarBlazorMaker).Assembly,
@*#endif*@
    };
}
