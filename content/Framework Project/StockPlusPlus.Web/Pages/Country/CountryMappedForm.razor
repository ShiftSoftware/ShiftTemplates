@attribute [Route($"/{nameof(CountryMappedForm)}/{{Key?}}")]

@using StockPlusPlus.Shared.DTOs

@* Create/edit form for the "api/countrymapped" endpoint (mapped via CountryMapper). *@
<ShiftEntityForm T="CountryMappedDTO"
                 Endpoint="CountryMapped"
                 Title="Country (Mapped)"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Country"
                 @bind-Key="@Key">

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Name"
                          @bind-Value="context.Item.Name"
                          For="@(() => context.Item.Name)" />
</ShiftEntityForm>

@code {
    [Parameter]
    public object? Key { get; set; }
}