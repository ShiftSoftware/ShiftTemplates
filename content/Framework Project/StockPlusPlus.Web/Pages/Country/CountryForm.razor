@attribute [Route($"/{nameof(CountryForm)}/{{Key?}}")]

@using StockPlusPlus.Shared.DTOs

<ShiftEntityForm @bind-Value="_theItem"
                 Endpoint="Country"
                 Title="Country"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Country"
                 @bind-Key="@Key">

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Name"
                          @bind-Value="context.Item.Name"
                          For="@(() => context.Item.Name)" />
</ShiftEntityForm>


@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public object? Key { get; set; }
    private CountryDTO _theItem = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Name))
        {
            _theItem.Name = Name;
        }
    }
}