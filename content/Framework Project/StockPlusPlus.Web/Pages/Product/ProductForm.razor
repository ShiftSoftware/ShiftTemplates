@attribute [Route($"/{nameof(ProductForm)}/{{Key?}}")]

@using ShiftSoftware.ShiftEntity.Model.Dtos
@using StockPlusPlus.Shared.DTOs.Product
@using StockPlusPlus.Shared.DTOs.ProductBrand
@using StockPlusPlus.Shared.DTOs.ProductCategory
@using StockPlusPlus.Shared.DTOs

@using Pages.ProductBrand
@using Pages.ProductCategory
@using Pages.Country
@using StockPlusPlus.Web.Attention
@using Microsoft.AspNetCore.Components.Forms

@implements IDisposable

@inherits ShiftForm<ProductForm, ProductDTO>
@inject ODataQuery odataQuery
@inject MockAttentionStore Attention
@inject IDialogService DialogService

<ShiftEntityForm @bind-Mode="Mode"
                 @bind-Value="TheItem"
                 @ref="FormContainer"
                 Endpoint="Product"
                 Title="Product"
                 @bind-ForceSaveAsNew="ForceSaveAsNew"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Product"
                 AllowClone
                 @bind-Key="@Key">

    <ToolbarEndTemplate>
        @if (!string.IsNullOrEmpty(Key?.ToString()))
        {
            <MudTooltip Text="Signal history">
                <MudButtonExtended Variant="Variant.Text"
                                   Color="Color.Tertiary"
                                   Style="min-width:40px;"
                                   aria-label="Signal history"
                                   OnClick="ShowSignalHistory">
                    <MudIcon Size="Size.Medium" Icon="@Icons.Material.Filled.NotificationsActive" />
                </MudButtonExtended>
            </MudTooltip>
        }
    </ToolbarEndTemplate>

    <ChildContent>
    <AttentionBanner Signals="snapshotSignals"
                     ShowAcknowledgeButton="false"
                     FooterNote="Automatically acknowledged on open" />

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Name"
                          @bind-Value="TheItem.Name"
                          For="@(() => TheItem.Name)" />

    <MudNumericFieldExtended @bind-Value="TheItem.Price" For="() => TheItem.Price" />

    <ShiftDateTimePicker Label="Release Date"
                         @bind-DateTimeOffset="TheItem.ReleaseDate"
                         For="() => TheItem.ReleaseDate" />

    <ShiftAutocomplete Label="Product Brand"
                       @bind-Value="TheItem.ProductBrand"
                       TEntitySet="ProductBrandListDTO"
                       EntitySet="ProductBrand"
                       QuickAddComponentType="typeof(ProductBrandForm)"
                       QuickAddParameterName="@nameof(ProductBrandForm.BrandName)"
                       For="() => TheItem.ProductBrand" />

    <ShiftAutocomplete Label="ProductCategory"
                       @bind-Value="TheItem.ProductCategory"
                       TEntitySet="ProductCategoryListDTO"
                       EntitySet="ProductCategory"
                       QuickAddComponentType="typeof(ProductCategoryForm)"
                       QuickAddParameterName="@nameof(ProductCategoryForm.ProductCategoryName)"
                       For="() => TheItem.ProductCategory" />


    <ShiftAutocomplete Label="Country"
                       @bind-Value="TheItem.CountryOfOrigin"
                       TEntitySet="CountryDTO"
                       EntitySet="Country"
                       QuickAddComponentType="typeof(CountryForm)"
                       QuickAddParameterName="@nameof(CountryForm.Name)"
                       For="()=> TheItem.CountryOfOrigin" />


    <MudSelectExtended @bind-Value="TheItem.TrackingMethod" For="() => TheItem.TrackingMethod"></MudSelectExtended>
    </ChildContent>

</ShiftEntityForm>


@code {
    [Parameter]
    public string? ProductCategoryID { get; set; }

    [Parameter]
    public string? ProductBrandID { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public bool ForceSaveAsNew { get; set; }

    private IReadOnlyList<AttentionSignal> snapshotSignals = Array.Empty<AttentionSignal>();
    private bool attentionCleared;
    private EditContext? gracePeriodContext;
    private DateTimeOffset graceEnd;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(ProductCategoryID))
        {
            TheItem.ProductCategory = new ShiftSoftware.ShiftEntity.Model.Dtos.ShiftEntitySelectDTO { Value = ProductCategoryID };
        }

        if (!string.IsNullOrWhiteSpace(ProductBrandID))
        {
            TheItem.ProductBrand = new ShiftSoftware.ShiftEntity.Model.Dtos.ShiftEntitySelectDTO { Value = ProductBrandID };
        }

        snapshotSignals = Attention.GetActive("Product", Key?.ToString());
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender && !attentionCleared && snapshotSignals.Count > 0)
        {
            attentionCleared = true;
            Attention.Clear("Product", Key?.ToString());
        }

        TryStartDirtyGracePeriod();
    }

    // Subscribe once to OnFieldChanged. During a short grace period after load, every field
    // change is assumed to be a spurious initial render from an input component (e.g. a
    // ShiftAutocomplete resolving its label async) and we re-mark the form as unmodified.
    // After the grace period expires, real user edits are honored normally.
    private void TryStartDirtyGracePeriod()
    {
        if (gracePeriodContext != null) return;
        if (string.IsNullOrEmpty(TheItem?.ID)) return;
        if (FormContainer?.EditContext is not { } ctx) return;

        gracePeriodContext = ctx;
        graceEnd = DateTimeOffset.Now.AddSeconds(3);
        ctx.MarkAsUnmodified();
        ctx.OnFieldChanged += HandleFieldChangedDuringGrace;
    }

    private void HandleFieldChangedDuringGrace(object? sender, FieldChangedEventArgs e)
    {
        if (sender is not EditContext ctx) return;

        if (DateTimeOffset.Now >= graceEnd)
        {
            ctx.OnFieldChanged -= HandleFieldChangedDuringGrace;
            gracePeriodContext = null;
            return;
        }

        ctx.MarkAsUnmodified();
    }

    public void Dispose()
    {
        if (gracePeriodContext != null)
        {
            gracePeriodContext.OnFieldChanged -= HandleFieldChangedDuringGrace;
            gracePeriodContext = null;
        }
    }

    private async Task ShowSignalHistory()
    {
        var id = Key?.ToString();
        if (string.IsNullOrEmpty(id)) return;

        var parameters = new DialogParameters
        {
            { "EntityType", "Product" },
            { "EntityId", id },
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };

        await DialogService.ShowAsync<AttentionHistoryDialog>("Signal history", parameters, options);
    }
}