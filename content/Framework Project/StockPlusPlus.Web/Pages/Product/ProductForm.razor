@attribute [Route($"/{nameof(ProductForm)}/{{Key?}}")]

@using ShiftSoftware.ShiftEntity.Model.Dtos
@using StockPlusPlus.Shared.DTOs.Product
@using StockPlusPlus.Shared.DTOs.ProductBrand
@using StockPlusPlus.Shared.DTOs.ProductCategory
@using StockPlusPlus.Shared.DTOs

@using Pages.ProductBrand
@using Pages.ProductCategory
@using Pages.Country

@inject ODataQuery odataQuery

@* Viewing presence demo: ReportViewingPresence makes the form tell the server, through the
   attention hub, that this record's form is open right now. Product.EvaluateAttention reads
   that presence (context.HasActiveViewers()) and skips raising "ReleasedWithoutPrice" while
   someone has the record open. Best-effort: when the hub is unreachable, the server treats
   the record as not viewed and raises signals as normal. *@
<ShiftEntityForm @bind-Value="_theItem"
                 @ref="FormContainer"
                 Endpoint="Product"
                 Title="Product"
                 @bind-ForceSaveAsNew="ForceSaveAsNew"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Product"
                 AllowClone
                 ClearAttentionOnOpen="true"
                 ReportViewingPresence="true"
                 @bind-Key="@Key">

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Name"
                          @bind-Value="context.Item.Name"
                          For="@(() => context.Item.Name)" />

    <MudNumericFieldExtended @bind-Value="context.Item.Price" For="() => context.Item.Price" />

    <ShiftDateTimePicker Label="Release Date"
                         @bind-DateTimeOffset="context.Item.ReleaseDate"
                         For="() => context.Item.ReleaseDate" />

    <ShiftAutocomplete Label="Product Brand"
                       @bind-Value="context.Item.ProductBrand"
                       TEntitySet="ProductBrandListDTO"
                       EntitySet="ProductBrand"
                       QuickAddComponentType="typeof(ProductBrandForm)"
                       QuickAddParameterName="@nameof(ProductBrandForm.BrandName)"
                       For="() => context.Item.ProductBrand" />

    <ShiftAutocomplete Label="ProductCategory"
                       @bind-Value="context.Item.ProductCategory"
                       TEntitySet="ProductCategoryListDTO"
                       EntitySet="ProductCategory"
                       QuickAddComponentType="typeof(ProductCategoryForm)"
                       QuickAddParameterName="@nameof(ProductCategoryForm.ProductCategoryName)"
                       For="() => context.Item.ProductCategory" />


    <ShiftAutocomplete Label="Country"
                       @bind-Value="context.Item.CountryOfOrigin"
                       TEntitySet="CountryDTO"
                       EntitySet="Country"
                       QuickAddComponentType="typeof(CountryForm)"
                       QuickAddParameterName="@nameof(CountryForm.Name)"
                       For="()=> context.Item.CountryOfOrigin" />


    <MudSelectExtended @bind-Value="context.Item.TrackingMethod" For="() => context.Item.TrackingMethod"></MudSelectExtended>

    @* Add (+) and view (double-click) use the framework's ShiftTagForm by default — no config needed. *@
    <ShiftTagPicker Label="Tags"
                    @bind-Value="context.Item.Tags" />

    @* Scoped-clear demo. Product's own "ReleasedWithoutPrice" signal is in the default scope and
       auto-clears on open (ClearAttentionOnOpen above). The compliance signal raised by
       ProductComplianceEvaluator is in the "Compliance" scope, so it survives open and is cleared
       only by this explicit action — the same pattern a chat tab would use to clear "Chat".
       (The banner also offers a per-signal dismiss on each row.) *@
    <MudButton OnClick="MarkComplianceReviewed"
               Variant="Variant.Outlined"
               Color="Color.Warning"
               StartIcon="@Icons.Material.Filled.Check"
               Size="Size.Small"
               Class="mt-2">
        Mark compliance reviewed
    </MudButton>

</ShiftEntityForm>


@code {
    [Parameter]
    public string? ProductCategoryID { get; set; }

    [Parameter]
    public string? ProductBrandID { get; set; }

    [Parameter]
    [SupplyParameterFromQuery]
    public bool ForceSaveAsNew { get; set; }

    [Parameter]
    public object? Key { get; set; }

    private ProductDTO _theItem = new();

    private ShiftEntityForm<ProductDTO>? FormContainer = null;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(ProductCategoryID))
        {
            _theItem.ProductCategory = new ShiftSoftware.ShiftEntity.Model.Dtos.ShiftEntitySelectDTO { Value = ProductCategoryID };
        }

        if (!string.IsNullOrWhiteSpace(ProductBrandID))
        {
            _theItem.ProductBrand = new ShiftSoftware.ShiftEntity.Model.Dtos.ShiftEntitySelectDTO { Value = ProductBrandID };
        }
    }

    // Scoped clear: clears only the "Compliance"-scoped signal(s), leaving any other active
    // signals untouched. Each surface clears only its own scope.
    // "Compliance" matches ProductComplianceEvaluator.Scope.
    private async Task MarkComplianceReviewed()
    {
        if (FormContainer is not null)
            await FormContainer.ClearAttention("Compliance");
    }
}