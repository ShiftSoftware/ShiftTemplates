@attribute [Route($"/{nameof(ProductCategoryForm)}/{{Key?}}")]

@using StockPlusPlus.Shared.DTOs.ProductCategory
@using StockPlusPlus.Shared.Enums

<ShiftEntityForm @bind-Value="_theItem"
                 ShowPrint
                 Endpoint="ProductCategory"
                 Title="Product Category"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.ProductCategory"
                 @bind-Key="@Key">

    <LocalizedTextField @bind-Value="context.Item.Name"
                        For="() => context.Item.Name"
                        Label="Name" />

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Description"
                          @bind-Value="context.Item.Description"
                          For="@(() => context.Item.Description)" />

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Code"
                          @bind-Value="context.Item.Code"
                          For="@(() => context.Item.Code)" />

    <FileUploader ShowThumbnail="true"
                  Label="Attachments"
                  TypeAuthAction="ShiftSoftware.ShiftEntity.Core.AzureStorageActionTree.UploadFiles"
                  For="() => context.Item.Photos"
                  AcceptImages="true"
                  @bind-Values="context.Item.Photos" />

    <MudSelectExtended OnlyValidateIfDirty="true"
                       T="TrackingMethod"
                       Label="Tracking Method"
                       AnchorOrigin="Origin.BottomLeft"
                       @bind-Value="context.Item.TrackingMethod"
                       For="@(() => context.Item.TrackingMethod)"/>

    @if (context.Mode == FormModes.View && !context.Embedded)
    {
        <br />
        <br />

        <ProductList ProductCategoryID="@context.Item.ID" />
    }
</ShiftEntityForm>


@code {
    [Parameter]
    public string? ProductCategoryName { get; set; }

    [Parameter]
    public object? Key { get; set; }

    private ProductCategoryDTO _theItem = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(ProductCategoryName))
        {
            _theItem.Name = ProductCategoryName;
        }
    }
}