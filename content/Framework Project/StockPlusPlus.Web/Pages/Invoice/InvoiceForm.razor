@attribute [Route($"/{nameof(InvoiceForm)}/{{Key?}}")]

@using ShiftSoftware.ShiftEntity.Model.Dtos
@using StockPlusPlus.Shared.DTOs.Invoice
@using StockPlusPlus.Shared.DTOs.Product
@using StockPlusPlus.Shared.DTOs

@using Pages.ProductBrand
@using Pages.ProductCategory
@using Pages.Country
@using StockPlusPlus.Web.Attention
@using Microsoft.AspNetCore.Components.Forms

@implements IDisposable

@inherits ShiftForm<InvoiceForm, InvoiceDTO>
@inject ODataQuery odataQuery
@inject MockAttentionStore Attention
@inject IDialogService DialogService

<ShiftEntityForm @bind-Mode="Mode"
                 @bind-Value="TheItem"
                 @ref="FormContainer"
                 Endpoint="Invoice"
                 Title="Invoice"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Invoice"
                 AllowClone
                 @bind-Key="@Key">

    <ToolbarEndTemplate>
        @if (!string.IsNullOrEmpty(Key?.ToString()))
        {
            <MudTooltip Text="Signal history">
                <MudButtonExtended Variant="Variant.Text"
                                   Color="Color.Tertiary"
                                   Style="min-width:40px;"
                                   aria-label="Signal history"
                                   OnClick="ShowSignalHistory">
                    <MudIcon Size="Size.Medium" Icon="@Icons.Material.Filled.NotificationsActive" />
                </MudButtonExtended>
            </MudTooltip>
        }
    </ToolbarEndTemplate>

    <ChildContent>
    <AttentionBanner Signals="ActiveSignals"
                     ShowAcknowledgeButton="true"
                     OnAcknowledge="HandleAcknowledge" />

    <MudTextFieldExtended OnlyValidateIfDirty="true"
                          Label="Manual Reference"
                          @bind-Value="TheItem.ManualReference"
                          For="@(() => TheItem.ManualReference)" />

    <ShiftDateTimePicker Clearable
                         Label="DateTime Picker"
                         Adornment="Adornment.End"
                         OnAdornmentClick="() => Console.WriteLine(234)"
                         @bind-DateTimeOffset="TheItem.InvoiceDate"
                         For="() => TheItem.InvoiceDate" />

    <MultiItemField DisableDragAndDrop="false" ControlVariant="Variant.Filled" Min="3" Title="Lines" @bind-Value="TheItem.InvoiceLines" T="InvoiceLineDTO">
        
        <FieldHeader Context="Field">
            <MudGrid Spacing="3" Style="align-items: baseline;">
                <MudItem lg="4" md="4" sm="4" xs="4">
                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Product</MudText>
                </MudItem>

                <MudItem lg="4" md="4" sm="4" xs="4">
                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Description</MudText>
                </MudItem>

                <MudItem lg="4" md="4" sm="4" xs="4">
                    <MudText Class="mud-text-with-border pb-3" Typo="Typo.subtitle2">Price</MudText>
                </MudItem>
            </MudGrid>
        </FieldHeader>

        <FieldBody Context="Item">
            <MudGrid Spacing="3" Style="align-items: baseline; margin-top: 0;">

                <MudItem Class="pt-1 pb-1" lg="4" md="4" sm="4" xs="4">
                    <ShiftAutocomplete Label="Product"
                                       @bind-Value="Item.Product"
                                       TEntitySet="ProductListDTO"
                                       EntitySet="Product"
                                       For="() => Item.Product" />
                </MudItem>

                <MudItem Class="pt-1 pb-1" lg="4" md="4" sm="4" xs="4">
                    <MudTextFieldExtended Label="Description"
                                          OnlyValidateIfDirty="false"
                                          @bind-Value="Item.Description"
                                          For="() => Item.Description" />
                </MudItem>

                <MudItem Class="pt-1 pb-1" lg="4" md="4" sm="4" xs="4">
                    <MudNumericFieldExtended Label="Price"
                                             OnlyValidateIfDirty="false"
                                             @bind-Value="Item.Price"
                                             For="() => Item.Price" />
                </MudItem>
            </MudGrid>
        </FieldBody>

        <ControlTemplate Context="_context">

            <MudButtonGroup Vertical>
                <MudIconButton ButtonType="ButtonType.Button"
                               Color="Color.Default"
                               OnClick="_context.MoveUp"
                               Icon="@Icons.Material.Filled.ArrowUpward" />
                <MudIconButton ButtonType="ButtonType.Button"
                               Color="Color.Default"
                               OnClick="_context.MoveDown"
                               Icon="@Icons.Material.Filled.ArrowDownward" />
                <MudIconButton ButtonType="ButtonType.Button"
                               Color="Color.Error"
                               OnClick="_context.MarkForRemoval"
                               Icon="@Icons.Material.Filled.Delete" />
                <MudIconButton ButtonType="ButtonType.Button"
                               Color="Color.Error"
                               OnClick="_context.MarkAllForRemoval"
                               Icon="@Icons.Material.Filled.Delete" />
            </MudButtonGroup>

        </ControlTemplate>
  
    </MultiItemField>
    </ChildContent>
</ShiftEntityForm>

@code {
    private EditContext? gracePeriodContext;
    private DateTimeOffset graceEnd;

    private IReadOnlyList<AttentionSignal> ActiveSignals =>
        Attention.GetActive("Invoice", Key?.ToString());

    private void HandleAcknowledge()
    {
        Attention.Clear("Invoice", Key?.ToString());
        StateHasChanged();
    }

    private async Task ShowSignalHistory()
    {
        var id = Key?.ToString();
        if (string.IsNullOrEmpty(id)) return;

        var parameters = new DialogParameters
        {
            { "EntityType", "Invoice" },
            { "EntityId", id },
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };

        await DialogService.ShowAsync<AttentionHistoryDialog>("Signal history", parameters, options);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        TryStartDirtyGracePeriod();
    }

    // See ProductForm — same workaround for the EditContext being spuriously marked modified
    // by input components firing ValueChanged on their initial post-load render.
    private void TryStartDirtyGracePeriod()
    {
        if (gracePeriodContext != null) return;
        if (string.IsNullOrEmpty(TheItem?.ID)) return;
        if (FormContainer?.EditContext is not { } ctx) return;

        gracePeriodContext = ctx;
        graceEnd = DateTimeOffset.Now.AddSeconds(3);
        ctx.MarkAsUnmodified();
        ctx.OnFieldChanged += HandleFieldChangedDuringGrace;
    }

    private void HandleFieldChangedDuringGrace(object? sender, FieldChangedEventArgs e)
    {
        if (sender is not EditContext ctx) return;

        if (DateTimeOffset.Now >= graceEnd)
        {
            ctx.OnFieldChanged -= HandleFieldChangedDuringGrace;
            gracePeriodContext = null;
            return;
        }

        ctx.MarkAsUnmodified();
    }

    public void Dispose()
    {
        if (gracePeriodContext != null)
        {
            gracePeriodContext.OnFieldChanged -= HandleFieldChangedDuringGrace;
            gracePeriodContext = null;
        }
    }
}