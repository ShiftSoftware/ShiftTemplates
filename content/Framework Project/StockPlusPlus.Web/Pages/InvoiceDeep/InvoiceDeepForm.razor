@attribute [Route($"/{nameof(InvoiceDeepForm)}/{{Key?}}")]

@using StockPlusPlus.Shared.DTOs.Invoice

@* Read-only view for "api/invoice-deep". Opening a row loads the invoice whose MapToView AUTOMATICALLY
   composed three levels: InvoiceLines → Product → ProductBrand (via the generated pair mappers). *@
<ShiftEntityForm T="InvoiceDeepDTO"
                 Endpoint="invoice-deep"
                 Title="Invoice (Deep)"
                 TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Invoice"
                 @bind-Key="@Key">

    <MudTextFieldExtended Label="Reference" @bind-Value="context.Item.ManualReference" ReadOnly="true" />
    <MudField Label="Invoice No" Variant="Variant.Text">@context.Item.InvoiceNo</MudField>

    <MudText Typo="Typo.h6" Class="mt-4 mb-2">Lines → Product → Brand (auto-composed)</MudText>

    <MudSimpleTable Dense="true" Bordered="true" Striped="true">
        <thead>
            <tr><th>Description</th><th>Price</th><th>Product</th><th>Product Price</th><th>Brand</th></tr>
        </thead>
        <tbody>
            @if (context.Item?.InvoiceLines is not null)
            {
                @foreach (var line in context.Item.InvoiceLines)
                {
                    <tr>
                        <td>@line.Description</td>
                        <td>@line.Price</td>
                        <td>@line.Product?.Name</td>
                        <td>@line.Product?.Price</td>
                        <td>@line.Product?.ProductBrand?.Name</td>
                    </tr>
                }
            }
        </tbody>
    </MudSimpleTable>
</ShiftEntityForm>

@code {
    [Parameter]
    public object? Key { get; set; }
}