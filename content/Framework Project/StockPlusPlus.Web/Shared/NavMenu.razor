@*#if (includeSampleApp)*@
@using ShiftSoftware.ShiftIdentity.Core
@using StockPlusPlus.Web.Pages.Country
@using StockPlusPlus.Web.Pages.Invoice
@using StockPlusPlus.Web.Pages.NeedsAttention
@using StockPlusPlus.Web.Pages.Product
@using StockPlusPlus.Web.Pages.ProductBrand
@using StockPlusPlus.Web.Pages.ProductCategory
@using StockPlusPlus.Web.Pages.CosmosCompanyBranch
@*#endif*@
<MudNavMenu>
    @*#if (includeSampleApp)*@
    <MudNavLink Href="@($"/{nameof(NeedsAttentionPage)}")"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Outlined.NotificationsActive">Needs Attention</MudNavLink>

    <AuthorizedMudNavGroup Title="Products" Icon="@Icons.Material.Filled.Book" HideExpandIcon="!isDrawerOpen" TypeAuthActions="new List<ShiftSoftware.TypeAuth.Core.Actions.Action> {
        StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.ProductBrand,
        StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.ProductCategory,
    }">
        <AuthorizedMudNavLink Href="@($"/{nameof(ProductBrandList)}")"
                              TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.ProductBrand"
                              Match="NavLinkMatch.All"
                              Icon="@Icons.Material.Outlined.Bookmarks">Brands</AuthorizedMudNavLink>

        <AuthorizedMudNavLink Href="@($"/{nameof(ProductCategoryList)}")"
                              TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.ProductCategory"
                              Match="NavLinkMatch.All"
                              Icon="@Icons.Material.Outlined.Discount">Categories</AuthorizedMudNavLink>

        <AuthorizedMudNavLink Href="@($"/{nameof(ProductList)}")"
                              TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Product"
                              Match="NavLinkMatch.All"
                              Icon="@Icons.Material.Outlined.Category">Products</AuthorizedMudNavLink>
    </AuthorizedMudNavGroup>

    <AuthorizedMudNavLink Href="@($"{nameof(InvoiceList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Newspaper"
                          TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Invoice">Invoices</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"/{nameof(CountryList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Public"
                          TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Country">Countries</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"/{nameof(CountryMappedList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Map"
                          TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Country">Countries (Mapped)</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="/tags"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Label"
                          TypeAuthAction="StockPlusPlus.Shared.ActionTrees.StockPlusPlusActionTree.Tags">Tags</AuthorizedMudNavLink>

    <AuthorizedMudNavLink Href="@($"{nameof(CosmosCompanyBranchList)}")"
                          Match="NavLinkMatch.All"
                          Icon="@Icons.Material.Outlined.Business"
                          TypeAuthAction="ShiftSoftware.ShiftIdentity.Core.ShiftIdentityActions.CompanyBranches">Branches (Cosmos)</AuthorizedMudNavLink>
    @*#endif*@
</MudNavMenu>

@code {
    [Parameter] public bool isDrawerOpen { get; set; }
}